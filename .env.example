# Tokens are stored in the OS keyring — run setup_tokens.py once per machine.
# Only use this file as a fallback if keyring is unavailable.
# NEVER commit real token values.

# Optional: override the default port (5002)
# PORT=5002

# --- Fallback only (keyring preferred) ---
# OKTA_ADMIN_DEV_API_TOKEN=your_dev_token_here
# OKTA_ADMIN_STG_API_TOKEN=your_stg_token_here
# OKTA_ADMIN_PROD_API_TOKEN=your_prod_token_here
